{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "presentation": {
        "reveal": "never",
        "group": "watchers"
      },
      "problemMatcher": {
        "owner": "esbuild",
        "source": "esbuild",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^\\[ERROR\\]\\s+(.*)$",
            "message": 1
          },
          {
            "regexp": "^\\s+(.*):(\\d+):(\\d+):?$",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[watch\\] build started$",
          "endsPattern": "^\\[watch\\] build finished$"
        }
      },
      "label": "npm: watch"
    },
    {
      "type": "shell",
      "command": "npm run compile",
      "group": "build",
      "problemMatcher": "$tsc",
      "label": "npm: compile"
    }
  ]
}
